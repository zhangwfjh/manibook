{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "manibook",
  "version": "0.1.0",
  "identifier": "com.manibook.dev",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "ManiBook",
        "width": 1280,
        "height": 960,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "pdfium.dll",
      "libpdfium.dylib",
      "libpdfium.so"
    ]
  }
}
