// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Document {
  id                String   @id @default(cuid())
  filename          String   @unique
  url               String
  doctype           String   // 'Article' | 'Book' | 'Others'
  title             String
  authors           String   // JSON array of authors as string
  publicationYear   Int?
  publisher         String?
  category          String
  language          String
  keywords          String   // JSON array of keywords as string
  abstract          String
  favorite          Boolean  @default(false)
  metadata          String?  // JSON string for additional metadata
  hash              String   @unique // SHA256 hash for duplicate detection
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  numPages          Int
  filesize          BigInt   // File size in bytes
  format            String   // File format: 'pdf' | 'epub' | 'djvu'

  @@map("documents")
}
